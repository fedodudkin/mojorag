# =============================================================================
# Dockerignore для MojoRAG
# Оптимизирован для Windows 10 + тестирования в контейнере
# =============================================================================

# =============================================================================
# Git
# =============================================================================
.git/
.gitignore
.gitattributes
.github/

# =============================================================================
# Python cache и виртуальные окружения
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
.pixi/
.venv/
venv/
env/
*.whl

# =============================================================================
# Mojo cache (компилируется заново в контейнере)
# =============================================================================
__mojocache__/
*.mojopkg

# =============================================================================
# IDE и редакторы
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
.cursorrules
.mypy_cache/
.ruff_cache/

# =============================================================================
# Данные и модели (монтируются как volume в docker-compose)
# =============================================================================
data/
models/
index/

# =============================================================================
# Документация (все .md и .docx)
# =============================================================================
docs/
*.md
*.docx
LICENSE

# =============================================================================
# Тесты — исключены из образа, НО доступны через volume в docker-compose
# =============================================================================
tests/
*.test.mojo
pytest.ini
.coverage
htmlcov/
.tox/
.nox/

# =============================================================================
# CI/CD
# =============================================================================
.github/
.gitlab-ci.yml
Jenkinsfile
.drone.yml

# =============================================================================
# Конфигурация
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Логи
# =============================================================================
*.log
logs/

# =============================================================================
# Временные файлы
# =============================================================================
tmp/
temp/
*.tmp
*.bak
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Docker
# =============================================================================
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# =============================================================================
# Скрипты загрузки (модели скачиваются на хосте)
# =============================================================================
scripts/
download_*.py

# =============================================================================
# Mojo-артефакты хоста
# =============================================================================
mojo_module.so
*.so.*

# =============================================================================
# Pixi (не используется при Docker-сборке)
# =============================================================================
pixi.toml
pixi.lock

# =============================================================================
# Makefile
# =============================================================================
Makefile