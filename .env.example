# =============================================================================
# MojoRAG — Пример файла переменных окружения
# Скопируйте этот файл в .env и настройте под себя:
#   cp .env.example .env
# =============================================================================

# Профиль оборудования: low_memory | balanced | performance | auto
MOJORAG_PROFILE=balanced

# Пути к данным
MOJORAG_DATA_DIR=./data
MOJORAG_MODELS_DIR=./models
MOJORAG_INDEX_DIR=./index

# LLM модель (относительно MODELS_DIR)
# balanced/low_memory: phi-3-mini-4k-instruct-q4.gguf
# performance: Llama-3-8B-Instruct-Q4_K_M.gguf
MOJORAG_LLM_MODEL=phi-3-mini-4k-instruct-q4.gguf

# Эмбеддинг-модель
MOJORAG_EMBED_MODEL=all-MiniLM-L6-v2

# API сервер
MOJORAG_HOST=0.0.0.0
MOJORAG_PORT=8000

# Параметры чанкинга
MOJORAG_CHUNK_SIZE=512
MOJORAG_CHUNK_OVERLAP=64
MOJORAG_MAX_CHUNKS_PER_QUERY=5

# HuggingFace (опционально — для скачивания моделей)
# HF_TOKEN=your_token_here
# HF_ENDPOINT=https://hf-mirror.com  # зеркало для РФ
